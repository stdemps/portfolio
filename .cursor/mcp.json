{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "stitch": {
      "command": "npx",
      "args": ["-y", "@_davideast/stitch-mcp@latest", "proxy"],
      "env": {
        "STITCH_USE_SYSTEM_GCLOUD": "1",
        "GOOGLE_CLOUD_PROJECT": "YOUR_GOOGLE_CLOUD_PROJECT_ID",
        "CI": "1",
        "DOTENV_CONFIG_QUIET": "true",
        "DOTENV_QUIET": "true",
        "NO_COLOR": "1"
      }
    }
  }
}
